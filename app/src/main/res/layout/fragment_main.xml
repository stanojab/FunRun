<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ═══ HEADER ═══ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FUNRUN"
                    android:textColor="@color/accent_lime"
                    android:textSize="24sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Go farther &amp; faster"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/settingsIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_settings"
                    android:padding="10dp"
                    android:background="@drawable/bg_icon_button"
                    android:tint="@color/text_secondary"
                    android:contentDescription="Settings" />

                <ImageView
                    android:id="@+id/addIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_add"
                    android:padding="10dp"
                    android:background="@drawable/bg_add_button"
                    android:tint="@color/bg_primary"
                    android:layout_marginStart="10dp"
                    android:contentDescription="Add run" />

            </LinearLayout>
        </RelativeLayout>

        <!-- ═══ PROGRESS RING ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WEEKLY GOAL"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.25"
                android:layout_marginBottom="16dp" />

            <FrameLayout
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center_horizontal">

                <com.mikhaellopez.circularprogressbar.CircularProgressBar
                    android:id="@+id/circularProgressBar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cpb_progressbar_color="@color/accent_lime"
                    app:cpb_progressbar_width="14dp"
                    app:cpb_background_progressbar_color="@color/bg_card"
                    app:cpb_background_progressbar_width="14dp"
                    app:cpb_round_border="true"
                    app:cpb_progress="0"
                    app:cpb_progress_direction="to_right" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/progressPercentageText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0"
                        android:textColor="@color/text_primary"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:lineSpacingMultiplier="0.85" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="km left"
                        android:textColor="@color/accent_lime"
                        android:textSize="12sp"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvDaysLeft"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7 days left"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </FrameLayout>

        </LinearLayout>

        <!-- ═══ SECTION HEADER: BEST THIS WEEK ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="14dp">

            <View
                android:layout_width="3dp"
                android:layout_height="14dp"
                android:background="@color/accent_lime"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR BEST THIS WEEK"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ═══ STATS CARDS ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Longest Distance -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:layout_marginBottom="10dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_accent_bar"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LONGEST DISTANCE"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/longestDistanceValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00 km"
                        android:textColor="@color/text_primary"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:lineSpacingMultiplier="0.95" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏃"
                    android:textSize="28sp" />

            </LinearLayout>

            <!-- Best Pace + Longest Duration -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:layout_marginEnd="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BEST PACE"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/bestPaceValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00"
                        android:textColor="@color/accent_lime"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginTop="2dp"
                        android:lineSpacingMultiplier="0.9" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="min/km"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:layout_marginStart="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LONGEST RUN"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/longestDurationValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent_lime"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginTop="2dp"
                        android:lineSpacingMultiplier="0.9" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="minutes"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ═══ SECTION HEADER: STREAK & CALENDAR ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp">

            <View
                android:layout_width="3dp"
                android:layout_height="14dp"
                android:background="@color/accent_lime"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="STREAK &amp; ACTIVITY"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStreakBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 day streak"
                android:textColor="@color/accent_lime"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Weekly calendar strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp">

            <LinearLayout android:id="@+id/dayMon" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_card" android:paddingVertical="12dp" android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="M" android:textColor="@color/text_secondary" android:textSize="10sp" android:textStyle="bold"/>
                <View android:id="@+id/dotMon" android:layout_width="7dp" android:layout_height="7dp" android:background="@color/text_muted" android:layout_marginTop="6dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/dayTue" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_card" android:paddingVertical="12dp" android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T" android:textColor="@color/text_secondary" android:textSize="10sp" android:textStyle="bold"/>
                <View android:id="@+id/dotTue" android:layout_width="7dp" android:layout_height="7dp" android:background="@color/text_muted" android:layout_marginTop="6dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/dayWed" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_card" android:paddingVertical="12dp" android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W" android:textColor="@color/text_secondary" android:textSize="10sp" android:textStyle="bold"/>
                <View android:id="@+id/dotWed" android:layout_width="7dp" android:layout_height="7dp" android:background="@color/text_muted" android:layout_marginTop="6dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/dayThu" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_card" android:paddingVertical="12dp" android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T" android:textColor="@color/text_secondary" android:textSize="10sp" android:textStyle="bold"/>
                <View android:id="@+id/dotThu" android:layout_width="7dp" android:layout_height="7dp" android:background="@color/text_muted" android:layout_marginTop="6dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/dayFri" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_card" android:paddingVertical="12dp" android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="F" android:textColor="@color/text_secondary" android:textSize="10sp" android:textStyle="bold"/>
                <View android:id="@+id/dotFri" android:layout_width="7dp" android:layout_height="7dp" android:background="@color/text_muted" android:layout_marginTop="6dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/daySat" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_card" android:paddingVertical="12dp" android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:textColor="@color/text_secondary" android:textSize="10sp" android:textStyle="bold"/>
                <View android:id="@+id/dotSat" android:layout_width="7dp" android:layout_height="7dp" android:background="@color/text_muted" android:layout_marginTop="6dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/daySun" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_card" android:paddingVertical="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:textColor="@color/text_secondary" android:textSize="10sp" android:textStyle="bold"/>
                <View android:id="@+id/dotSun" android:layout_width="7dp" android:layout_height="7dp" android:background="@color/text_muted" android:layout_marginTop="6dp"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>