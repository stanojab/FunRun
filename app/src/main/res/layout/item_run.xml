<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Distance Label -->
        <TextView
            android:id="@+id/distanceTextLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Distance:"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Distance Data -->
        <TextView
            android:id="@+id/distanceTextData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text=""
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/distanceTextLabel"
            app:layout_constraintTop_toTopOf="@id/distanceTextLabel" />

        <!-- Duration Label -->
        <TextView
            android:id="@+id/durationTextLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Duration:"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/distanceTextLabel"
            app:layout_constraintVertical_chainStyle="packed" />

        <!-- Duration Data -->
        <TextView
            android:id="@+id/durationTextData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text=""
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/durationTextLabel"
            app:layout_constraintTop_toTopOf="@id/durationTextLabel" />

        <!-- Pace Label -->
        <TextView
            android:id="@+id/paceTextLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pace:"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/durationTextLabel" />

        <!-- Pace Data -->
        <TextView
            android:id="@+id/paceTextData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text=""
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/paceTextLabel"
            app:layout_constraintTop_toTopOf="@id/paceTextLabel" />

        <!-- Date Label -->
        <TextView
            android:id="@+id/dateTextLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date:"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/paceTextLabel" />

        <!-- Date Data -->
        <TextView
            android:id="@+id/dateTextData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text=""
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/dateTextLabel"
            app:layout_constraintTop_toTopOf="@id/dateTextLabel" />

        <!-- Run Icon -->
        <ImageView
            android:id="@+id/runIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="Run Icon"
            android:src="@drawable/ic_run"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
