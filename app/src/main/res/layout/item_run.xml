<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="10dp">

    <!-- Left: lime accent dot / icon -->
    <LinearLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@color/accent_lime_alpha"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginEnd="14dp">

        <!-- Use an ImageView with your runner icon here if available -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏃"
            android:textSize="20sp" />

    </LinearLayout>

    <!-- Center: main stats -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Distance — prominent -->
        <TextView
            android:id="@+id/distanceTextData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00 km"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed" />

        <!-- Pace + Duration row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/paceTextData"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0 km/h"
                android:textColor="@color/accent_lime"
                android:textSize="12sp" />

            <View
                android:layout_width="3dp"
                android:layout_height="3dp"
                android:background="@color/text_muted"
                android:layout_marginHorizontal="6dp" />

            <TextView
                android:id="@+id/durationTextData"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Date -->
        <TextView
            android:id="@+id/dateTextData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2024-01-01 00:00"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginTop="3dp" />

    </LinearLayout>

</LinearLayout>